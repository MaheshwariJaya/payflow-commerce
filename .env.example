PORT=3000
NODE_ENV=development

# Database connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payflow?schema=public

# Redis connection (used for locks, rate limiting, and BullMQ queues)
REDIS_URL=redis://localhost:6379

# AES encryption key (MUST be 32 bytes/64 hex characters)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# JWT Secrets & API Keys
JWT_SECRET=supersecretjwtkeyforpayflow
ADMIN_API_KEY=admin-key-12345

# Mock Webhook validation secrets (used by simulator)
STRIPE_WEBHOOK_SECRET=whsec_stripe_test_secret
RAZORPAY_WEBHOOK_SECRET=whsec_razorpay_test_secret
PAYU_WEBHOOK_SECRET=whsec_payu_test_secret
UPI_WEBHOOK_SECRET=whsec_upi_test_secret
